# Home Assistant Dashboard Builder - Example Configuration
# Copy this file to .env and fill in your values

# Home Assistant Connection Settings
HA_HOST=192.168.1.50
HA_PORT=8123
HA_ACCESS_TOKEN=your_long_lived_access_token_here

# Database Configuration (SQLite by default)
DATABASE_URL=sqlite:///./ha_dashboard.db

# Application Settings
APP_NAME=HA Dashboard Builder
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# WebSocket Poll Interval (seconds) - how often to check HA for state changes
WS_POLL_INTERVAL=5.0
