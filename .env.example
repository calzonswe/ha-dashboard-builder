# ---------------------------------------------------------------------------
# Environment Variables for HA Dashboard Builder
# Copy this file to .env and fill in your values before running Docker Compose.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# ============================================================================
# Home Assistant Connection
# ============================================================================

# Host of your Home Assistant instance (e.g., 192.168.1.50)
HA_HOST=localhost

# Port of your Home Assistant instance (default: 8123)
HA_PORT=8123

# Long-lived access token for Home Assistant authentication.
# Generate one at: Home Assistant > Settings > Users > Your User > Long-Lived Access Tokens
HA_ACCESS_TOKEN=your-long-lived-access-token-here

# ============================================================================
# WebSocket Settings
# ============================================================================

# How often the server polls HA for state changes, in seconds (default: 5.0)
WS_POLL_INTERVAL=5.0

# ============================================================================
# LLM Settings (optional - configured via Settings UI instead)
# ============================================================================

# LLM Provider: "ollama" or "lmstudio" (default: ollama)
# LLM_PROVIDER=ollama

# LLM Model name (default: llama3.2 for Ollama)
# LLM_MODEL=llama3.2

# Base URL for LLM (default: http://localhost:11434 for Ollama)
# LLM_BASE_URL=http://localhost:11434
