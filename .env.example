# ---------------------------------------------------------------------------
# Environment Variables for HA Dashboard Builder
# Copy this file to .env and fill in your values before running Docker Compose.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# ============================================================================
# Home Assistant Connection
# ============================================================================

# URL of your Home Assistant instance (e.g., http://192.168.1.50:8123)
HA_INTEGRATION_HA_URL=http://localhost:8123

# Long-lived access token for Home Assistant authentication.
# Generate one at: Home Assistant > Settings > Users > Your User > Long-Lived Access Tokens
HA_INTEGRATION_HA_TOKEN=your-long-lived-access-token-here

# HTTP request timeout to HA in seconds (default: 10)
HA_INTEGRATION_HA_TIMEOUT=10.0

# Maximum number of retries when connecting to HA (default: 3)
HA_INTEGRATION_HA_MAX_RETRIES=3

# Delay between retry attempts in seconds (default: 1.0)
HA_INTEGRATION_HA_RETRY_DELAY=1.0

# ============================================================================
# Server Settings
# ============================================================================

# Bind address for the API server (default: 0.0.0.0)
HA_INTEGRATION_HOST=0.0.0.0

# Port to listen on (default: 8000)
HA_INTEGRATION_PORT=8000

# ============================================================================
# Security
# ============================================================================

# API key for Bearer-token authentication.
# Set this in production to protect all endpoints except /health and /api/health.
# Leave empty or unset to disable authentication (development only).
HA_INTEGRATION_API_KEY=change-me-in-production

# ============================================================================
# Entity Cache Settings
# ============================================================================

# How long cached entity data is considered fresh, in seconds (default: 60)
HA_INTEGRATION_CACHE_TTL_SECONDS=60

# Interval at which the cache background refresh runs, in seconds (default: 300 / 5 min)
HA_INTEGRATION_CACHE_REFRESH_INTERVAL=300

# ============================================================================
# WebSocket Keepalive Settings
# ============================================================================

# How often the server sends a ping to keep WebSocket connections alive, in seconds (default: 30)
HA_INTEGRATION_WS_PING_INTERVAL=30.0

# Maximum time (in seconds) to wait for a pong response before considering the connection dead (default: 10)
HA_INTEGRATION_WS_PING_TIMEOUT=10.0
